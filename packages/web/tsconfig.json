{
  // Strategy 2: exactOptionalPropertyTypes and verbatimModuleSyntax are
  // enforced globally (tsconfig.base.json) but relaxed here for the web
  // package.  Prompt-kit-installed vendor files in src/components/ui/ emit
  // errors under both flags and AGENTS.md Rule 3 forbids modifying them.
  // All seven other @lifecoach/* packages inherit the full strict suite.
  // Revisit once prompt-kit upstream ships strictness-clean component types.
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "outDir": "dist",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "types": ["vite/client"],
    "paths": {
      "~/*": ["./src/*"],
      "@/*": ["./src/*"]
    },
    "exactOptionalPropertyTypes": false,
    "verbatimModuleSyntax": false
  },
  "include": ["src/**/*", "vite.config.ts"],
  "exclude": ["src/stories/**/*"]
}
