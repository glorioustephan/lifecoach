{
  "name": "lifecoach",
  "version": "0.0.1",
  "private": true,
  "description": "Personal life/health coach agent — Claude Agent SDK + SQLite memory + MCP server",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "lifecoach": "pnpm --filter @lifecoach/cli start",
    "mcp": "pnpm --filter @lifecoach/mcp-server start",
    "typecheck": "pnpm -r typecheck",
    "build": "pnpm -r build",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
