{
  "name": "lifecoach",
  "version": "0.0.1",
  "private": true,
  "description": "Personal life/health coach agent — Claude Agent SDK + SQLite memory + MCP server",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "lifecoach": "pnpm --filter @lifecoach/cli start",
    "mcp": "pnpm --filter @lifecoach/mcp-server start",
    "server": "pnpm --filter @lifecoach/server start",
    "web:dev": "pnpm --filter @lifecoach/web dev",
    "web:build": "pnpm --filter @lifecoach/web build",
    "dev": "pnpm --parallel --filter @lifecoach/server --filter @lifecoach/web run dev",
    "start": "pnpm web:build && pnpm server",
    "typecheck": "pnpm -r typecheck",
    "build": "pnpm -r build",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@11.1.0"
}
