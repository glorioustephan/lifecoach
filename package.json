{
  "name": "lifecoach",
  "version": "0.0.1",
  "private": true,
  "description": "Personal life/health coach agent — Claude Agent SDK + SQLite memory + MCP server",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev:setup": "bash scripts/dev-setup.sh",
    "dev": "pnpm dev:setup && pnpm --parallel --filter @lifecoach/server --filter @lifecoach/web run dev",
    "dev:reset": "rm -rf data-dev && pnpm dev",
    "deploy:macmini": "bash scripts/deploy-to-macmini.sh",
    "deploy:macmini:env": "bash scripts/deploy-env-to-macmini.sh",
    "deploy:production": "bash scripts/deploy-production.sh",
    "lifecoach": "pnpm --filter @lifecoach/cli start",
    "mcp": "pnpm --filter @lifecoach/mcp-server start",
    "server": "pnpm --filter @lifecoach/server start",
    "web:dev": "pnpm --filter @lifecoach/web dev",
    "web:build": "pnpm --filter @lifecoach/web build",
    "start": "pnpm web:build && LIFECOACH_SERVE_BUILT_WEB=1 pnpm --filter @lifecoach/server start",
    "typecheck": "pnpm -r typecheck",
    "build": "pnpm -r build",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@11.1.0"
}
