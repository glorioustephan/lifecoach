# Copy this file to .env.local (local dev) or .env.production (production).
# See README.md for the full environment variable reference.
#
# Environment selection — drives the data directory (data-development/, data-production/, etc.)
# and which .env.{env} file is loaded by the config loader.
# Default is "development" when not set.
LIFECOACH_ENV=development

# ─── Required ────────────────────────────────────────────────────────────────

# Anthropic API key for Claude Agent SDK (chat, extraction, reflection, insights)
ANTHROPIC_API_KEY=sk-ant-...

# ─── Recommended ─────────────────────────────────────────────────────────────

# Voyage AI API key for semantic embeddings.
# Without this, recall() degrades to keyword (LIKE) fallback.
# Use a SEPARATE key for dev vs. production to keep embedding indexes isolated.
# Add a $5–10/mo billing cap in the Voyage dashboard.
VOYAGE_API_KEY=

# ─── Auth ────────────────────────────────────────────────────────────────────

# Set to "off" to disable email allow-list checks (safe for local dev on Tailscale).
# In production, remove this line and set LIFECOACH_ALLOWED_EMAILS instead.
LIFECOACH_AUTH=off

# Comma-separated list of emails allowed to access the web UI (production only).
# LIFECOACH_ALLOWED_EMAILS=you@example.com

# ─── Integrations (all optional) ─────────────────────────────────────────────

# Todoist personal API token. Get from Todoist → Settings → Integrations →
# Developer → API token. Enables task sync (runs automatically every 30 min in
# production via PM2, or manually with: pnpm lifecoach sync todoist).
TODOIST_API_TOKEN=

# Capacities API token. Generate from Capacities desktop app →
# Settings → Capacities API. Enables:
#   - lifecoach sync capacities  →  mirrors objects into local memory
#   - save_to_daily_note and save_to_capacities agent tools
#   - automatic write-back of daily/weekly reflections into your daily note
CAPACITIES_API_TOKEN=

# Default Capacities space id. Required for reflection write-back and as the
# fallback target for write-back tools. Find it via: lifecoach sync capacities
# (logged on first run) or GET /api/sources/capacities/spaces.
CAPACITIES_DEFAULT_SPACE_ID=

# ─── Model overrides (optional) ───────────────────────────────────────────────

# Chat model. Default: claude-sonnet-4-6 (strong + ~5x cheaper than Opus).
# Set to claude-opus-4-7 for maximum reasoning, claude-haiku-4-5-20251001 for speed.
# LIFECOACH_MODEL=claude-sonnet-4-6

# Extraction model (used during ingestion). Defaults to Sonnet.
# LIFECOACH_EXTRACTION_MODEL=claude-sonnet-4-6

# ─── Storage ──────────────────────────────────────────────────────────────────

# Override the data directory path. If unset, defaults to data-{LIFECOACH_ENV}.
# Rarely needed — prefer LIFECOACH_ENV to pick dev/production.
# LIFECOACH_DATA_DIR=

# Embedding dimension. Must match your embedder model. Voyage voyage-3 = 1024.
# LIFECOACH_EMBEDDING_DIM=1024

# ─── Server ───────────────────────────────────────────────────────────────────

# HTTP server port. Default: 3717.
# PORT=3717
