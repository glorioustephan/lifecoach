# Copy this file to .env and fill in your keys.
#
# Required: Anthropic API key for the Claude Agent SDK
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Voyage AI API key for semantic embeddings.
# If unset, recall() will degrade to keyword fallback (LIKE search)
# until you wire the local @xenova/transformers embedder.
VOYAGE_API_KEY=

# Optional: Todoist personal API token. Get from Todoist → Settings →
# Integrations → Developer → API token. Required for `lifecoach sync todoist`.
TODOIST_API_TOKEN=

# Optional: override the default model. Default is claude-sonnet-4-6 — strong
# at chat + tool use and ~5x cheaper than Opus. Set to claude-opus-4-7 if you
# want maximum reasoning depth, or claude-haiku-4-5-20251001 for even cheaper.
LIFECOACH_MODEL=claude-sonnet-4-6

# Optional: override the data directory (default: ./data)
LIFECOACH_DATA_DIR=

# Optional: override the embedding dimension (must match the embedder)
# Voyage voyage-3 → 1024
LIFECOACH_EMBEDDING_DIM=1024

CAPACITIES_API_TOKEN=